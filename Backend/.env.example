# Groq Cloud API key — get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use (default shown below)
GROQ_MODEL=openai/gpt-oss-20b

# System prompt sent to the model on every conversation
SYSTEM_PROMPT=You are a helpful AI assistant. Be concise and clear.

# Supabase PostgreSQL — direct connection string
# Found in: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres
